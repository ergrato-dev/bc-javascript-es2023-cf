# ============================================
# .npmrc — Configuración de pnpm
# ============================================

# ✅ REGLA DE ORO: todas las dependencias se instalan con versión EXACTA.
# PROHIBIDO usar ^ (caret) o >= (mayor-igual) en package.json.
# Esto previene actualizaciones silenciosas que pueden introducir CVEs.
save-exact=true

# Requiere pnpm-lock.yaml en el repositorio (lockfile obligatorio)
lockfile=true

# Modo estricto: falla si el lockfile no está actualizado
frozen-lockfile=false

# Evitar que scripts de instalación de dependencias se ejecuten
# sin aprobación explícita (prevención de supply-chain attacks)
ignore-scripts=false
